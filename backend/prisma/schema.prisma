generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  email        String    @unique
  name         String?
  provider     String    // oauth provider name (google, apple, etc.)
  providerId   String    // provider user id

  currency     String    @default("USD")
  simplified   Boolean   @default(true)
  // Used for Safe to Spend Today: (monthlyBudgetAmount - spentThisMonth) / daysLeftInMonth
  monthlyBudgetAmount Decimal?

  accounts     Account[]
  categories   Category[]
  budgets      Budget[]
  goals        Goal[]
  transactions Transaction[]
  coachPrompts CoachPrompt[]
  reflections   Reflection[]
  coachCheckIns CoachCheckIn[]
}

model Account {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  name      String
  type      String       // e.g. CASH, BANK, CARD
  balance   Decimal      @default(0)

  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]
}

model Category {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  name      String
  type      CategoryType
  color     String       // hex color
  icon      String?      // optional icon name
  sortOrder Int          @default(0)

  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  budgets      Budget[]
  reflections  Reflection[]
}

model Budget {
  id          String       @id @default(cuid())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  name        String
  periodStart DateTime
  periodEnd   DateTime
  amount      Decimal

  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId  String?
  category    Category?    @relation(fields: [categoryId], references: [id])
}

model Transaction {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  amount    Decimal
  date      DateTime
  note      String?
  spendType SpendType    @default(PLANNED) // Planned or Impulsive — drives coach loop

  accountId String
  account   Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category?   @relation(fields: [categoryId], references: [id])

  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoachPrompt {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptKey String   // e.g. "impulsive_reflection_1"
  shownAt   DateTime @default(now())
}

model Reflection {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  feelingKey String    // e.g. anxious, guilty, relieved, fine, not_sure
  reasonKey  String    // e.g. stressed, bored, with_friends, saw_deal, not_sure
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model CoachCheckIn {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  dueAt       DateTime
  prompt      String
  source      String    @default("fallback")
  status      String    @default("due")
  shownAt     DateTime?
  dismissedAt DateTime?
  completedAt DateTime?

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  name        String
  targetAmount Decimal
  currentAmount Decimal @default(0)
  targetDate   DateTime?

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum SpendType {
  PLANNED
  IMPULSIVE
}

