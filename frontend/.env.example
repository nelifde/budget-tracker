# Optional: leave unset to use same-origin /api (Next.js proxies to the backend — recommended for Docker and local dev).
# Set only if the API is on another origin (e.g. frontend on Vercel, API elsewhere).
# NEXT_PUBLIC_API_URL=https://api.example.com

# Used by next.config.js rewrites (build time). Docker Compose sets this via the frontend image build args.
# BACKEND_URL=http://127.0.0.1:4000
